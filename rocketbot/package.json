        {
            "en": {
                "title": "Send data",
                "description": "Send a data row to a BotMonitor table",
                "title_options": "Select Option",
                "options": null
            },
            "es": {
                "title": "Enviar datos",
                "description": "Envia una fila de datos a una tabla de BotMonitor",
                "title_options": "Seleccione una opcion",
                "options": null
            },
            "form": {
                "css": "modal-lg",
                "inputs": [
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Solicitudes",
                            "en": "Requests"
                        },
                        "title": {
                            "es": "Nombre de la tabla:",
                            "en": "Table name:"
                        },
                        "description": {
                            "es": "Nombre de la tabla de datos destino.",
                            "en": "Target data table name."
                        },
                        "id": "table",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "[{\"name\":\"email\",\"type\":\"text\",\"label\":\"Email\"}]",
                            "en": "[{\"name\":\"email\",\"type\":\"text\",\"label\":\"Email\"}]"
                        },
                        "title": {
                            "es": "Columnas (JSON, solo primera vez):",
                            "en": "Columns (JSON, first time only):"
                        },
                        "description": {
                            "es": "Definicion de columnas en JSON. Requerido solo al crear la tabla por primera vez.",
                            "en": "Column definition in JSON. Required only when creating the table for the first time."
                        },
                        "id": "columns",
                        "css": "col-md-12"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "{\"email\": \"user@example.com\", \"status\": \"OK\"}",
                            "en": "{\"email\": \"user@example.com\", \"status\": \"OK\"}"
                        },
                        "title": {
                            "es": "Datos de fila (JSON):",
                            "en": "Row data (JSON):"
                        },
                        "description": {
                            "es": "Objeto JSON con los datos de la fila.",
                            "en": "JSON object with the row data."
                        },
                        "id": "row",
                        "css": "col-md-12"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Variable",
                            "en": "Variable"
                        },
                        "title": {
                            "es": "Asignar resultado a variable:",
                            "en": "Assign result to variable:"
                        },
                        "description": {
                            "es": "Variable para almacenar la respuesta del servidor.",
                            "en": "Variable to store the server response."
                        },
                        "help": {
                            "es": "Nombre de variable sin {}",
                            "en": "Variable name without {}"
                        },
                        "remove_vars": true,
                        "id": "whereToStore",
                        "css": "col-md-6"
                    }
                ]
            },
