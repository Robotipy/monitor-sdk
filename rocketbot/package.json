        },
        {
            "en": {
                "title": "Upload SQLite database",
                "description": "Upload all tables and rows from a SQLite file, skipping duplicates by primary key columns",
                "title_options": "Select Option",
                "options": null
            },
            "es": {
                "title": "Subir base de datos SQLite",
                "description": "Envia todas las tablas y filas de un archivo SQLite, omitiendo duplicados segun las columnas primary key",
                "title_options": "Seleccione una opcion",
                "options": null
            },
            "form": {
                "css": "modal-lg",
                "inputs": [
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "https://botmonitor.example.com",
                            "en": "https://botmonitor.example.com"
                        },
                        "title": {
                            "es": "URL de la API:",
                            "en": "API URL:"
                        },
                        "description": {
                            "es": "URL del servidor BotMonitor. Si se deja vacio, se usa la conexion establecida por 'Conectar a BotMonitor'.",
                            "en": "BotMonitor server URL. If left empty, uses the connection set by 'Connect to BotMonitor'."
                        },
                        "id": "api_url",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "bm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
                            "en": "bm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
                        },
                        "title": {
                            "es": "API Key:",
                            "en": "API Key:"
                        },
                        "description": {
                            "es": "API Key del usuario generada en BotMonitor. Opcional si ya se conecto previamente.",
                            "en": "User API Key generated in BotMonitor. Optional if already connected previously."
                        },
                        "id": "api_key",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "UUID del bot",
                            "en": "Bot UUID"
                        },
                        "title": {
                            "es": "Bot ID:",
                            "en": "Bot ID:"
                        },
                        "description": {
                            "es": "UUID del bot al que pertenecen los datos. Opcional si ya se conecto previamente.",
                            "en": "UUID of the bot that owns the data. Optional if already connected previously."
                        },
                        "id": "bot_id",
                        "css": "col-md-12"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "C:\\data\\mydata.sqlite",
                            "en": "C:\\data\\mydata.sqlite"
                        },
                        "title": {
                            "es": "Ruta del archivo SQLite:",
                            "en": "SQLite file path:"
                        },
                        "description": {
                            "es": "Ruta local al archivo .sqlite/.db que se subira al backend.",
                            "en": "Local path to the .sqlite/.db file to upload to the backend."
                        },
                        "id": "dbPath",
                        "css": "col-md-12"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "id,tenant",
                            "en": "id,tenant"
                        },
                        "title": {
                            "es": "Columnas primary key (separadas por coma):",
                            "en": "Primary key columns (comma-separated):"
                        },
                        "description": {
                            "es": "Columnas que identifican filas unicas. Si la tabla no las contiene, se usan los PK declarados en el schema SQLite. Opcional.",
                            "en": "Columns that uniquely identify rows. If the table does not contain them, the PKs declared in the SQLite schema are used. Optional."
                        },
                        "id": "primaryKeys",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "500",
                            "en": "500"
                        },
                        "title": {
                            "es": "Filas por lote (opcional):",
                            "en": "Rows per batch (optional):"
                        },
                        "description": {
                            "es": "Numero de filas enviadas por request HTTP. Default: 500.",
                            "en": "Number of rows sent per HTTP request. Default: 500."
                        },
                        "id": "batchSize",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Variable",
                            "en": "Variable"
                        },
                        "title": {
                            "es": "Asignar resultado a variable:",
                            "en": "Assign result to variable:"
                        },
                        "description": {
                            "es": "Variable para almacenar el resumen de la carga (filas insertadas/omitidas por tabla).",
                            "en": "Variable to store the upload summary (rows inserted/skipped per table)."
                        },
                        "help": {
                            "es": "Nombre de variable sin {}",
                            "en": "Variable name without {}"
                        },
                        "remove_vars": true,
                        "id": "whereToStore",
                        "css": "col-md-6"
                    }
                ]
            },
