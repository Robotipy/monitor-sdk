        },
        {
            "en": {
                "title": "Send log",
                "description": "Send a log entry to BotMonitor",
                "title_options": "Select Option",
                "options": null
            },
            "es": {
                "title": "Enviar log",
                "description": "Envia un registro de log a BotMonitor",
                "title_options": "Seleccione una opcion",
                "options": null
            },
            "form": {
                "css": "modal-lg",
                "inputs": [
                    {
                        "type": "select",
                        "title": {
                            "es": "Nivel de log:",
                            "en": "Log level:"
                        },
                        "options": [
                            {
                                "title": "--Select--",
                                "value": ""
                            },
                            {
                                "title": "INFO",
                                "value": "INFO"
                            },
                            {
                                "title": "WARNING",
                                "value": "WARNING"
                            },
                            {
                                "title": "ERROR",
                                "value": "ERROR"
                            },
                            {
                                "title": "CRITICAL",
                                "value": "CRITICAL"
                            }
                        ],
                        "description": {
                            "es": "Nivel del log a enviar.",
                            "en": "Log level to send."
                        },
                        "id": "level",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Bot inicio procesamiento",
                            "en": "Bot started processing"
                        },
                        "title": {
                            "es": "Mensaje:",
                            "en": "Message:"
                        },
                        "description": {
                            "es": "Descripcion del evento.",
                            "en": "Event description."
                        },
                        "id": "message",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "{\"key\": \"value\"}",
                            "en": "{\"key\": \"value\"}"
                        },
                        "title": {
                            "es": "Payload (JSON, opcional):",
                            "en": "Payload (JSON, optional):"
                        },
                        "description": {
                            "es": "Datos arbitrarios en formato JSON.",
                            "en": "Arbitrary data in JSON format."
                        },
                        "id": "payload",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "1500",
                            "en": "1500"
                        },
                        "title": {
                            "es": "Duracion en ms (opcional):",
                            "en": "Duration in ms (optional):"
                        },
                        "description": {
                            "es": "Duracion del proceso en milisegundos.",
                            "en": "Process duration in milliseconds."
                        },
                        "id": "durationMs",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Variable",
                            "en": "Variable"
                        },
                        "title": {
                            "es": "Asignar resultado a variable:",
                            "en": "Assign result to variable:"
                        },
                        "description": {
                            "es": "Variable para almacenar la respuesta del servidor.",
                            "en": "Variable to store the server response."
                        },
                        "help": {
                            "es": "Nombre de variable sin {}",
                            "en": "Variable name without {}"
                        },
                        "remove_vars": true,
                        "id": "whereToStore",
                        "css": "col-md-6"
                    }
                ]
            },
