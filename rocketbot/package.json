        {
            "en": {
                "title": "Connect to BotMonitor",
                "description": "Initialize connection to BotMonitor API",
                "title_options": "Select Option",
                "options": null
            },
            "es": {
                "title": "Conectar a BotMonitor",
                "description": "Inicializa la conexion con la API de BotMonitor",
                "title_options": "Seleccione una opcion",
                "options": null
            },
            "form": {
                "css": "modal-lg",
                "inputs": [
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "https://botmonitor.example.com",
                            "en": "https://botmonitor.example.com"
                        },
                        "title": {
                            "es": "URL de la API:",
                            "en": "API URL:"
                        },
                        "description": {
                            "es": "URL del servidor BotMonitor",
                            "en": "BotMonitor server URL"
                        },
                        "id": "api_url",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "bm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
                            "en": "bm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
                        },
                        "title": {
                            "es": "API Key:",
                            "en": "API Key:"
                        },
                        "description": {
                            "es": "API Key del bot generada en BotMonitor",
                            "en": "Bot API Key generated in BotMonitor"
                        },
                        "id": "api_key",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "UUID del bot",
                            "en": "Bot UUID"
                        },
                        "title": {
                            "es": "Bot ID:",
                            "en": "Bot ID:"
                        },
                        "description": {
                            "es": "UUID del bot al que pertenecen los datos.",
                            "en": "UUID of the bot that owns the data."
                        },
                        "id": "bot_id",
                        "css": "col-md-6"
                    },
                    {
                        "type": "input",
                        "placeholder": {
                            "es": "Variable",
                            "en": "Variable"
                        },
                        "title": {
                            "es": "Asignar resultado a variable:",
                            "en": "Assign result to variable:"
                        },
                        "description": {
                            "es": "Variable para almacenar el resultado de la conexion (True/False).",
                            "en": "Variable to store the connection result (True/False)."
                        },
                        "help": {
                            "es": "Nombre de variable sin {}",
                            "en": "Variable name without {}"
                        },
                        "remove_vars": true,
                        "id": "whereToStore",
                        "css": "col-md-6"
                    }
                ]
            },
